{
  "name": "vellum-editor",
  "version": "1.0.0",
  "private": true,
  "description": "An opinionated diagram editor — keyboard-first like Excalidraw, structured like draw.io.",
  "license": "SEE LICENSE IN LICENSE",
  "author": "Josh Morris",
  "homepage": "https://github.com/blueprintr-io/vellum",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/blueprintr-io/vellum"
  },
  "bugs": {
    "url": "https://github.com/blueprintr-io/vellum/issues"
  },
  "keywords": [
    "diagram",
    "editor",
    "draw",
    "excalidraw",
    "drawio",
    "svg",
    "react",
    "vite"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./styles.css": "./src/styles/globals.css"
  },
  "files": [
    "src",
    "scripts/sync-iconpacks.mjs",
    "legal",
    "tsconfig.json",
    "tailwind.config.ts",
    "postcss.config.js",
    "vite.config.ts",
    "index.html",
    "README.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "node scripts/sync-iconpacks.mjs && vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "sync:icons": "node scripts/sync-iconpacks.mjs",
    "prebuild": "node scripts/sync-iconpacks.mjs"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "dependencies": {
    "@fontsource/architects-daughter": "^5.2.7",
    "@fontsource/caveat": "^5.2.8",
    "@fontsource/fira-code": "^5.2.7",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/lora": "^5.2.8",
    "@fontsource/outfit": "^5.2.8",
    "@fontsource/patrick-hand": "^5.2.8",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.4",
    "dompurify": "^3.4.1",
    "yaml": "^2.6.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/jsdom": "^28.0.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "jsdom": "^29.0.2",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
