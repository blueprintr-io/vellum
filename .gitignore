# dependencies
node_modules

# build output
dist
dist-ssr
dist-*/

# vite/tsc artefacts
.vite
*.local
*.tsbuildinfo
vite.config.ts.timestamp-*.mjs

# OS
.DS_Store
Thumbs.db

